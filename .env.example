# OpenTypeless 配置文件示例
# 实际生效文件名：.env

# 服务监听
DOUBAO_ASR_HOST=0.0.0.0
DOUBAO_ASR_PORT=8000

# 网关鉴权（可选）
DOUBAO_ASR_API_KEY=sk-your-gateway-key

# 默认后端：ime / official
DOUBAO_ASR_DEFAULT_BACKEND=official

# 官方录音文件识别模式：standard / flash
# 这里默认极速版
DOUBAO_ASR_OFFICIAL_MODE=flash

# 官方鉴权（必填）
DOUBAO_ASR_OFFICIAL_APP_KEY=your-app-key
DOUBAO_ASR_OFFICIAL_ACCESS_KEY=your-access-key

# Spokenly 推荐模型：doubao-asr-official-flash
# 若需标准版：
# 1) 直接在 Spokenly 模型里填 doubao-asr-official-standard
# 或 2) 保持模型 doubao-asr-official，同时把 DOUBAO_ASR_OFFICIAL_MODE 改成 standard

# 官方资源ID（一般不需要改）
DOUBAO_ASR_OFFICIAL_STANDARD_RESOURCE_ID=volc.seedasr.auc
DOUBAO_ASR_OFFICIAL_FLASH_RESOURCE_ID=volc.bigasr.auc_turbo

# 官方模型参数（一般不需要改）
DOUBAO_ASR_OFFICIAL_MODEL_NAME=bigmodel
DOUBAO_ASR_OFFICIAL_UID=opentypeless

# 标准版轮询参数（standard 模式才会用到）
DOUBAO_ASR_OFFICIAL_QUERY_INTERVAL_SEC=1.0
DOUBAO_ASR_OFFICIAL_QUERY_TIMEOUT_SEC=300
